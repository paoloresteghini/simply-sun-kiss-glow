---
const steps = [
  {
    n: '01',
    title: 'Exfoliate 24h Before',
    desc: 'Use a gentle, oil-free scrub the day prior to remove dead cells. Pay attention to elbows, knees, ankles, and hands.',
    icon: 'exfoliate',
  },
  {
    n: '02',
    title: 'Shave or Wax 24h+ Prior',
    desc: 'Hair removal closes pores best when done a day in advance. Avoid same-day shaving to prevent uneven uptake.',
    icon: 'razor',
  },
  {
    n: '03',
    title: 'Skip Lotions & Oils',
    desc: 'Arrive with clean, product-free skin. No moisturizer, makeup, perfume, or deodorant on tan day.',
    icon: 'drop',
  },
  {
    n: '04',
    title: 'Wear Loose, Dark Clothing',
    desc: 'Loose fabrics protect your fresh tan from friction. Dark colors hide any minor transfer before your first rinse.',
    icon: 'shirt',
  },
];

const detailImg = 'https://images.unsplash.com/photo-1556228578-8c89e6adf883?auto=format&fit=crop&w=1000&q=85';
---

<section id="prep" class="relative section-padding py-28 lg:py-40 bg-cream overflow-hidden">
  <div class="grid grid-cols-12 gap-6 lg:gap-16 items-start">
    <!-- Sticky text panel -->
    <div class="col-span-12 lg:col-span-5 lg:sticky lg:top-32">
      <p class="eyebrow reveal mb-5">Spray Tan Prep</p>
      <h2 class="reveal reveal-delay-1 font-display font-light text-walnut text-[clamp(2.4rem,5.5vw,4.2rem)] leading-[1] tracking-tight balance">
        Prepping for<br />
        <span class="font-italic-display text-bronze">your glow.</span>
      </h2>
      <p class="reveal reveal-delay-2 mt-6 text-walnut/70 leading-relaxed max-w-md">
        A little prep makes a big difference. Follow these four steps in the 24 hours before your appointment for the smoothest, longest-lasting tan.
      </p>

      <div class="reveal reveal-delay-3 mt-10 relative h-80 hidden lg:block overflow-hidden">
        <img src={detailImg} alt="Amber bottle and tan mitt on warm linen" width="1000" height="800" class="h-full w-full object-cover kenburns" loading="lazy" />
      </div>
    </div>

    <!-- Steps list -->
    <div class="col-span-12 lg:col-span-7 lg:pl-10">
      <ol class="divide-y divide-bronze/20 border-y border-bronze/20">
        {steps.map((s, i) => (
          <li class="group py-8 lg:py-10 grid grid-cols-12 gap-4 items-start reveal" style={`transition-delay: ${i * 100}ms`}>
            <div class="col-span-2 md:col-span-1">
              <span class="font-italic-display text-bronze text-3xl">{s.n}</span>
            </div>
            <div class="col-span-8 md:col-span-9">
              <h3 class="font-display text-2xl md:text-3xl text-walnut leading-tight">{s.title}</h3>
              <p class="mt-2 text-walnut/70 max-w-lg leading-relaxed">{s.desc}</p>
            </div>
            <div class="col-span-2 flex justify-end">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-bronze/40 text-bronze transition-all duration-500 group-hover:bg-bronze group-hover:text-cream group-hover:rotate-90">
                {s.icon === 'exfoliate' && (
                  <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="6" cy="6" r="1.5"/><circle cx="12" cy="9" r="1.5"/><circle cx="18" cy="6" r="1.5"/><circle cx="9" cy="15" r="1.5"/><circle cx="15" cy="18" r="1.5"/><circle cx="6" cy="18" r="1.5"/></svg>
                )}
                {s.icon === 'razor' && (
                  <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M4 4l8 8m4 4l4 4M14 10l-4 4"/><rect x="3" y="3" width="3" height="3"/></svg>
                )}
                {s.icon === 'drop' && (
                  <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M12 2.5c4 5 7 8.5 7 12a7 7 0 11-14 0c0-3.5 3-7 7-12z"/></svg>
                )}
                {s.icon === 'shirt' && (
                  <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M4 7l4-4h8l4 4-3 3v10H7V10z"/></svg>
                )}
              </span>
            </div>
          </li>
        ))}
      </ol>

      <div class="reveal mt-10 p-8 bg-linen/60 border border-bronze/20">
        <div class="divider-ornament mb-4 text-bronze">
          <span class="font-italic-display text-lg">tip</span>
        </div>
        <p class="text-walnut/80 text-center max-w-xl mx-auto leading-relaxed">
          Bring loose dark clothing and slip-on shoes for the trip home. Avoid leggings, bras with elastic, and anything that hugs the skin while your tan develops.
        </p>
      </div>
    </div>
  </div>
</section>
