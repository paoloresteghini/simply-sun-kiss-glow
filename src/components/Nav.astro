---
const links = [
  { href: '#about', label: 'About' },
  { href: '#services', label: 'Services' },
  { href: '#prep', label: 'Prep' },
  { href: '#aftercare', label: 'Aftercare' },
  { href: '#gallery', label: 'Gallery' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contact', label: 'Contact' },
];
---

<nav
  data-nav
  class="fixed top-0 inset-x-0 z-50 flex items-center justify-between px-6 md:px-12 lg:px-20 pt-6 pb-4 border-b border-transparent"
>
  <a href="#top" class="group flex items-center gap-3" aria-label="Simply Sun Kiss Glow home">
    <span class="relative inline-flex h-11 w-11 items-center justify-center rounded-full overflow-hidden border border-bronze/40 bg-cream shadow-sm transition-transform duration-500 group-hover:scale-105">
      <img src={`${import.meta.env.BASE_URL}/images/logo.jpg`.replace(/\/+/g, '/')} alt="Simply Sun Kiss Glow logo" width="44" height="44" class="h-full w-full object-cover" />
    </span>
    <span class="flex flex-col leading-none">
      <span class="font-display text-[15px] tracking-wide text-walnut">Simply Sun Kiss</span>
      <span class="font-italic-display text-[15px] -mt-0.5 text-bronze">Glow</span>
    </span>
  </a>

  <ul class="hidden lg:flex items-center gap-9">
    {links.map((l) => (
      <li>
        <a
          href={l.href}
          class="group relative text-[11px] uppercase tracking-extra-wide font-medium text-walnut/70 hover:text-walnut transition-colors duration-300"
        >
          {l.label}
          <span class="absolute -bottom-1.5 left-0 h-px w-0 bg-bronze transition-all duration-500 group-hover:w-full"></span>
        </a>
      </li>
    ))}
  </ul>

  <div class="hidden lg:block">
    <a href="#contact" class="btn-primary !py-3 !px-6">Book Now <span aria-hidden>→</span></a>
  </div>

  <button
    data-burger
    aria-label="Toggle menu"
    class="lg:hidden flex flex-col gap-1.5 p-2"
  >
    <span class="block h-px w-6 bg-walnut"></span>
    <span class="block h-px w-6 bg-walnut"></span>
    <span class="block h-px w-6 bg-walnut"></span>
  </button>
</nav>

<div data-menu class="fixed inset-0 z-40 bg-cream/98 lg:hidden flex flex-col items-center justify-center gap-8 pt-20">
  {links.map((l) => (
    <a href={l.href} class="font-display text-3xl text-walnut hover:text-bronze transition-colors">
      {l.label}
    </a>
  ))}
  <a href="#contact" class="btn-primary mt-6">Book Now <span aria-hidden>→</span></a>
</div>
