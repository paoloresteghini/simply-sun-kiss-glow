---
const tips = [
  { hour: '0–8h', title: 'Let it Develop', desc: 'No water, no sweat, no friction. Keep it loose, keep it dry.' },
  { hour: '8h', title: 'First Rinse', desc: 'Warm (not hot) water. Rinse only — no soap, no scrubbing. Pat dry.' },
  { hour: 'Daily', title: 'Moisturize', desc: 'Apply a sulfate-free, oil-free moisturizer morning and night.' },
  { hour: 'Always', title: 'Be Gentle', desc: 'Pat dry. No loofahs. Quick lukewarm showers extend your glow.' },
];

const safeProducts = [
  { brand: 'Native', kind: 'Coconut & Vanilla Body Wash', note: 'Sulfate-free, perfect for tanned skin.' },
  { brand: 'Aveeno', kind: 'Skin Relief Body Wash', note: 'Fragrance-free, soothes sensitive skin.' },
  { brand: 'Shea Moisture', kind: 'Raw Shea Butter Wash', note: 'Locks in moisture, extends fade.' },
  { brand: 'Method', kind: 'Simply Nourish Coconut', note: 'Plant-based and ultra hydrating.' },
];
---

<section id="aftercare" class="relative section-padding py-28 lg:py-40 bg-walnut text-cream overflow-hidden">
  <!-- Decorative leaf shadow -->
  <div aria-hidden class="pointer-events-none absolute -top-20 -right-32 opacity-15 rotate-12">
    <svg viewBox="0 0 400 400" class="h-[500px] w-[500px]" fill="none" stroke="#C9A57C" stroke-width="0.5">
      <path d="M200 50 C 280 100, 340 180, 350 280 M200 50 C 240 130, 260 220, 240 320 M200 50 C 280 130, 310 230, 290 330 M200 50 C 260 110, 290 200, 280 290 M200 50 C 220 120, 220 240, 200 320 M200 50 C 170 130, 150 230, 160 320 M200 50 C 130 100, 80 200, 70 290" stroke-linecap="round"/>
    </svg>
  </div>

  <div class="relative">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
      <div>
        <p class="eyebrow text-tan reveal mb-5">Aftercare</p>
        <h2 class="reveal reveal-delay-1 font-display font-light text-cream text-[clamp(2.4rem,5.5vw,4.5rem)] leading-[1] tracking-tight balance">
          Keep your glow,<br />
          <span class="font-italic-display text-tan">longer.</span>
        </h2>
      </div>
      <p class="reveal reveal-delay-2 max-w-md text-cream/70 lg:text-right">
        A well-cared-for tan lasts 7–10 days. The right products keep it even, the wrong ones strip it overnight.
      </p>
    </div>

    <!-- Timeline -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-cream/15 mb-20">
      {tips.map((t, i) => (
        <div class="bg-walnut p-6 md:p-8 reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="eyebrow text-tan">{t.hour}</div>
          <h3 class="font-display text-2xl text-cream mt-3 leading-tight">{t.title}</h3>
          <p class="mt-3 text-sm text-cream/70 leading-relaxed">{t.desc}</p>
        </div>
      ))}
    </div>

    <!-- Safe products -->
    <div class="grid grid-cols-12 gap-6 lg:gap-12 items-center">
      <div class="col-span-12 lg:col-span-5">
        <p class="eyebrow text-tan reveal mb-4">Tan-Safe Picks</p>
        <h3 class="reveal reveal-delay-1 font-display text-3xl md:text-4xl text-cream leading-tight">
          Body washes that <span class="font-italic-display text-tan">protect your tan.</span>
        </h3>
        <p class="reveal reveal-delay-2 mt-5 text-cream/70 leading-relaxed max-w-md">
          Look for sulfate-free, fragrance-light, and gently hydrating formulas. These are our salon-tested favorites.
        </p>
        <div class="reveal reveal-delay-3 mt-8 divider-ornament text-tan">
          <span class="font-italic-display text-lg">tested · loved</span>
        </div>
      </div>

      <div class="col-span-12 lg:col-span-7">
        <ul class="grid sm:grid-cols-2 gap-px bg-cream/15">
          {safeProducts.map((p, i) => (
            <li class="bg-walnut p-6 group transition-colors hover:bg-espresso reveal" style={`transition-delay: ${i * 80}ms`}>
              <div class="font-display text-cream text-xl">{p.brand}</div>
              <div class="eyebrow text-tan mt-1">{p.kind}</div>
              <p class="mt-3 text-sm text-cream/65">{p.note}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Avoid callout -->
    <div class="reveal mt-16 border border-tan/30 p-6 md:p-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <div class="eyebrow text-tan">Avoid</div>
        <p class="font-display text-xl md:text-2xl text-cream mt-2">
          Hot showers · loofahs · sulfates · retinol · chlorine · long baths
        </p>
      </div>
      <span class="font-italic-display text-tan text-2xl">they strip your glow.</span>
    </div>
  </div>
</section>
