---
const faqs = [
  { q: 'How long does a spray tan last?', a: 'A well-prepped, properly maintained tan lasts 7–10 days. Daily moisturizing with sulfate-free products and gentle lukewarm rinsing can extend it further. Hot showers, loofahs, and chlorine will shorten it.' },
  { q: 'Will it turn orange or streaky?', a: 'Never. Every tan is hand-blended to your undertone — cool, warm, or neutral — for a natural bronze. Our airbrush technique ensures even, streak-free coverage across the whole body.' },
  { q: 'What is in the solution?', a: 'Naturally-derived DHA combined with organic botanicals, hyaluronic acid, and aloe. Our formulas are 100% vegan, paraben-free, gluten-free, and made without harsh chemicals or synthetic fragrance.' },
  { q: 'How should I prepare?', a: 'Exfoliate 24 hours before, shave or wax 24+ hours prior, and arrive with clean, product-free skin. Wear loose dark clothing and slip-on shoes to your appointment.' },
  { q: 'When can I shower?', a: 'For our Signature tan, wait 8 hours. For Express, you can rinse in 1–4 hours depending on your desired depth. Rinse with warm water only — no soap on the first rinse.' },
  { q: 'Is it safe during pregnancy?', a: 'DHA only interacts with the top layer of skin and is widely considered safe during pregnancy. We recommend checking with your physician and avoiding inhalation by wearing a nose plug, which we provide.' },
  { q: 'Where do you operate? Do you have a studio?', a: 'We are 100% mobile — we do not operate a fixed studio. We bring a pop-up cabin and full professional kit directly to your home, hotel, or venue. We service Sarasota, Bradenton, Lakewood Ranch, Siesta Key, Longboat Key, Anna Maria Island, Venice, and surrounding Gulf Coast communities. Travel beyond available on request.' },
  { q: 'What space do you need for the mobile setup?', a: 'A small private area roughly 6x6 feet (a bathroom, bedroom corner, or balcony works) plus an electrical outlet. We bring the cabin, fan, lighting, drop cloths, towels, and all product. Setup takes about 10 minutes.' },
  { q: 'What if I have sensitive skin?', a: 'We offer a fragrance-free, hypoallergenic formula on request. Patch tests are available 24 hours before your first appointment.' },
];
---

<section id="faq" class="relative section-padding py-28 lg:py-40 bg-sand overflow-hidden">
  <div class="grid grid-cols-12 gap-6 lg:gap-16 items-start">
    <div class="col-span-12 lg:col-span-4 lg:sticky lg:top-32">
      <p class="eyebrow reveal mb-5">Frequently Asked</p>
      <h2 class="reveal reveal-delay-1 font-display font-light text-walnut text-[clamp(2.4rem,5.5vw,4.2rem)] leading-[1] tracking-tight balance">
        Good<br />
        <span class="font-italic-display text-bronze">to know.</span>
      </h2>
      <p class="reveal reveal-delay-2 mt-6 text-walnut/70 max-w-sm leading-relaxed">
        Everything you might want to ask before your first appointment. Still curious? Send a note via the contact form.
      </p>
    </div>

    <div class="col-span-12 lg:col-span-8">
      <ul class="divide-y divide-bronze/25 border-y border-bronze/25">
        {faqs.map((f, i) => (
          <li class="reveal" style={`transition-delay: ${i * 60}ms`}>
            <details class="group py-6 lg:py-7">
              <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
                <span class="font-display text-walnut text-lg md:text-xl leading-snug pr-4">{f.q}</span>
                <span class="shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-full border border-bronze/40 text-bronze transition-all duration-500 group-open:rotate-45 group-open:bg-bronze group-open:text-cream">
                  <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
                </span>
              </summary>
              <div class="mt-4 pr-12 text-walnut/70 leading-relaxed max-w-2xl">
                {f.a}
              </div>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
